TAVILY_API_KEY=your_tavily_api_key_here

# LLM routing: GEMINI (default) or GROQ
# GEMINI → tries Gemini first, falls back to Groq if it fails
# GROQ   → tries Groq first, falls back to Gemini if it fails
LLM_TYPE=GROQ

# Gemini config
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# Groq config (optional — enables Groq as a provider)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — suppresses HuggingFace unauthenticated warning
HF_TOKEN=your_huggingface_token_here
